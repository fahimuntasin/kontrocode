# KontroCode environment configuration
# Copy to .env and fill in. Never commit .env.

# Default mode for the model router: cost | speed | quality
KONTROCODE_ROUTER_MODE=cost

# Provider API keys (BYOK). Stored in OS keychain in production.
# At least one is required for real LLM use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=

# Monthly budget cap in USD (0 = unlimited)
KONTROCODE_MONTHLY_BUDGET_USD=0

# Telemetry: off by default
KONTROCODE_TELEMETRY=off

# Backend: file | redis
KONTROCODE_MEMORY_BACKEND=file
REDIS_URL=

# Log level: trace | debug | info | warn | error
RUST_LOG=info,kontrocode=debug
