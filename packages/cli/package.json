{
  "name": "@kontrocode/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "kontrocode": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist .tsbuild"
  },
  "dependencies": {
    "chalk": "5.3.0",
    "commander": "12.1.0"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "eslint": "9.14.0",
    "prettier": "3.3.3",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
