{
  "name": "kontrocode",
  "version": "0.1.0",
  "private": true,
  "description": "KontroCode — The Agent That Knows Before It Codes.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter './apps/*' --filter './packages/*' build",
    "dev": "pnpm --filter @kontrocode/desktop tauri dev",
    "dev:cli": "pnpm --filter @kontrocode/cli dev",
    "lint": "pnpm -r lint",
    "lint:tokens": "node scripts/check-tokens.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:rust": "cargo test --workspace",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "format": "pnpm -r format && cargo fmt --all",
    "format:check": "pnpm -r format:check && cargo fmt --all -- --check",
    "clean": "pnpm -r clean && cargo clean",
    "release": "pnpm build && cargo build --release --workspace",
    "prepare": "pnpm -r --filter './packages/*' build"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "prettier": "3.3.3"
  }
}
